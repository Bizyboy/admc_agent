# ADMC Agent — Environment Variables
# Copy this file to .env and fill in your values.
# The agent reads API keys from environment variables, not from config files.

# --- LLM Provider API Key ---
# Set the key for your chosen provider (configured in config.yaml under llm.provider)

# xAI Grok (default provider — get a free key at https://console.x.ai)
XAI_API_KEY=xai-your-grok-api-key-here

# Groq (fast free alternative — get a key at https://console.groq.com)
# GROQ_API_KEY=gsk-your-groq-api-key-here

# OpenAI (if switching to provider: openai with OpenAI's endpoint)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (if using provider: anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Optional: Override config.yaml values via environment ---
# Format: ADMC_<SECTION>_<KEY>=value
# Examples:
# ADMC_LLM_MODEL=grok-3
# ADMC_LLM_MODEL=grok-3-mini
# ADMC_LLM_PROVIDER=openai
# ADMC_AGENT_NAME=MyCompanion
# ADMC_API_PORT=9000
# ADMC_MEMORY_DB_PATH=/path/to/custom/memory.db
