# ADMC Agent - Environment Variables
# Copy this file to .env and fill in your values

# xAI Grok API key (get free at https://console.x.ai)
XAI_API_KEY=xai-your-key-here

# Discord Bot Token (get at https://discord.com/developers/applications)
# 1. Create a new application
# 2. Go to Bot section, create a bot, copy the token
# 3. Enable Message Content Intent under Privileged Gateway Intents
# 4. Invite bot to your server with these permissions: Send Messages, Read Messages
DISCORD_TOKEN=your-discord-bot-token-here

# Reddit Bot Credentials (get at https://www.reddit.com/prefs/apps)
# 1. Go to reddit.com/prefs/apps
# 2. Create a new app (script type)
# 3. Fill in client_id (under app name) and client_secret
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
# Comma separated list of subreddits to watch (no r/ prefix)
REDDIT_SUBREDDITS=test,ArtificialIntelligence
