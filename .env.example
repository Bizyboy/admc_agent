# ADMC Agent — Environment Variables
# Copy this file to .env and fill in your values.
# The agent reads API keys from environment variables, not from config files.

# --- LLM Provider API Key ---
# Set the key for your chosen provider (configured in config.yaml under llm.provider)

# OpenAI (default provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (if using provider: anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Optional: Override config.yaml values via environment ---
# Format: ADMC_<SECTION>_<KEY>=value
# Examples:
# ADMC_LLM_MODEL=gpt-4o
# ADMC_LLM_PROVIDER=anthropic
# ADMC_AGENT_NAME=MyCompanion
# ADMC_API_PORT=9000
# ADMC_MEMORY_DB_PATH=/path/to/custom/memory.db
